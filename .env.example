# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and must NEVER be committed.

# --- LLM provider ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: switch LLM provider without code changes. Default: "gemini"
# Supported: "gemini" | "groq"  (groq added later)
LLM_PROVIDER=gemini

# Model name for the chosen provider. Sensible defaults are used if unset.
# Gemini examples: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash
LLM_MODEL=gemini-2.5-flash

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
