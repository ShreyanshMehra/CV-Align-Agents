# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored and must NEVER be committed.

# --- LLM provider ---
# Choose ONE provider via LLM_PROVIDER. Supported: "gemini" | "groq".
LLM_PROVIDER=groq

# Gemini: get a free key at https://aistudio.google.com/apikey
# (Note: gemini-2.5-flash free tier is ~20 requests/day.)
GOOGLE_API_KEY=your-gemini-api-key-here

# Groq: get a free key (no card) at https://console.groq.com/keys
# Much higher free tier (~14,400 requests/day).
GROQ_API_KEY=your-groq-api-key-here

# Model name for the chosen provider. Sensible defaults are used if unset.
#   gemini -> gemini-2.5-flash | gemini-2.0-flash
#   groq   -> llama-3.3-70b-versatile
LLM_MODEL=llama-3.3-70b-versatile

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
